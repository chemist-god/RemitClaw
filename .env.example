# ── Celo / Mento ──────────────────────────────────────────────
CELO_RPC_URL=https://forno.celo.org
CELO_CHAIN_ID=42220
# CELO_SEPOLIA_RPC_URL=https://forno.celo-sepolia.celo-testnet.org
# CELO_CHAIN_ID=11142220

# Wallet used by the agent for swap + transfer execution (never commit real keys)
AGENT_PRIVATE_KEY=

# ── OpenClaw / LLM ────────────────────────────────────────────
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
# Primary LLM for OpenClaw (see openclaw.json → openrouter/anthropic/claude-sonnet-4)
# Get a key: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Optional direct providers (not used while OpenRouter is the default):
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# ANTHROPIC_API_KEY=

# ── Twilio / WhatsApp notifications ─────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SMS_FROM=

# ── Security & limits ─────────────────────────────────────────
DAILY_TRANSFER_LIMIT_USD=500
SINGLE_TRANSFER_LIMIT_USD=200
REQUIRE_CONFIRMATION_ABOVE_USD=100
# Swap slippage tolerance in basis points (50 = 0.5%)
SLIPPAGE_BPS=50

# ── Agent API server (web ↔ agent bridge) ────────────────────
AGENT_API_PORT=8787
# Optional shared secret; if set, callers must send header x-api-key
AGENT_API_KEY=
# CORS origin for the web app (dev: http://localhost:3000 | prod: https://remifi.xyz)
WEB_ORIGIN=http://localhost:3000
# Fallback recipient for demo sends when a contact has no wallet address
DEMO_RECIPIENT_ADDRESS=

# RemifiVault escrow contract — required for phone-only sends (claim link flow)
# Deploy: cd contract && forge script script/RemifiVault.s.sol:RemifiVaultScript --broadcast
REMIFI_VAULT_ADDRESS=

# ── ERC-8004 agent identity ──────────────────────────────────
# Registry addresses auto-resolve from CELO_CHAIN_ID when unset:
#   Mainnet (42220):  Identity 0x8004A169…  Reputation 0x8004BAa1…
#   Sepolia (11142220): Identity 0x8004A818…  Reputation 0x8004B663…
# Override only if needed:
# IDENTITY_REGISTRY_ADDRESS=
# REPUTATION_REGISTRY_ADDRESS=
# Set after `npm run register` — binds the hosted /.well-known/agent.json card.
AGENT_ID=
# agentURI priority: AGENT_URI → PUBLIC_BASE_URL/.well-known/agent.json → data: URI
AGENT_URI=
AGENT_NAME=Remifi
# AGENT_DESCRIPTION=
# AGENT_IMAGE=https://remifi.xyz/assets/img1.png
# PUBLIC_BASE_URL=https://remifi.xyz
# PUBLIC_AGENT_API_URL=https://api.remifi.xyz
# AGENT_URI=https://remifi.xyz/.well-known/agent.json

# ── x402 payments (docs.celo.org x402 + thirdweb facilitator) ─
X402_ENABLED=false
X402_PRICE_USD=0.01
X402_NETWORK=celo
# Settlement token: USDC (default, 6dp) or USDm (18dp)
X402_TOKEN=USDC
# thirdweb secret key — enables real verify/settle via facilitator (portal.thirdweb.com)
THIRDWEB_SECRET_KEY=

# ── App ───────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
DATA_DIR=./data
