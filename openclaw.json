{
  "models": {
    "mode": "merge",
    "providers": {
      "openrouter": {
        "apiKey": "${OPENROUTER_API_KEY}"
      }
    }
  },
  "agents": {
    "defaults": {
      "skills": ["remifi"],
      "model": "openrouter/anthropic/claude-sonnet-4"
    },
    "list": [
      {
        "id": "remifi",
        "name": "Remifi",
        "workspace": ".",
        "skills": ["remifi"]
      }
    ]
  },
  "skills": {
    "entries": {
      "remifi": {
        "enabled": true,
        "env": {
          "CELO_RPC_URL": "${CELO_RPC_URL}",
          "CELO_CHAIN_ID": "${CELO_CHAIN_ID}",
          "AGENT_PRIVATE_KEY": "${AGENT_PRIVATE_KEY}",
          "AGENT_ID": "${AGENT_ID}",
          "DEMO_RECIPIENT_ADDRESS": "${DEMO_RECIPIENT_ADDRESS}",
          "DATA_DIR": "${DATA_DIR}"
        }
      }
    },
    "load": {
      "extraDirs": ["./skills"],
      "watch": true
    }
  },
  "channels": {
    "whatsapp": {
      "enabled": false
    }
  }
}
