{
  "models": {
    "mode": "merge",
    "providers": {
      "openrouter": {
        "apiKey": "${OPENROUTER_API_KEY}"
      }
    }
  },
  "agents": {
    "defaults": {
      "skills": ["remifi"],
      "model": "openrouter/anthropic/claude-sonnet-4"
    },
    "list": [
      {
        "id": "remifi",
        "name": "Remifi",
        "workspace": ".",
        "skills": ["remifi"]
      }
    ]
  },
  "skills": {
    "entries": {
      "remifi": {
        "enabled": true,
        "env": {
          "CELO_RPC_URL": "${CELO_RPC_URL}",
          "CELO_CHAIN_ID": "${CELO_CHAIN_ID}",
          "AGENT_PRIVATE_KEY": "${AGENT_PRIVATE_KEY}",
          "DATA_DIR": "${DATA_DIR}",
          "AGENT_API_PORT": "8787",
          "AGENT_ID": "${AGENT_ID}",
          "DEMO_RECIPIENT_ADDRESS": "${DEMO_RECIPIENT_ADDRESS}",
          "REMIFI_VAULT_ADDRESS": "${REMIFI_VAULT_ADDRESS}",
          "PUBLIC_BASE_URL": "${PUBLIC_BASE_URL}",
          "TWILIO_ACCOUNT_SID": "${TWILIO_ACCOUNT_SID}",
          "TWILIO_AUTH_TOKEN": "${TWILIO_AUTH_TOKEN}",
          "TWILIO_WHATSAPP_FROM": "${TWILIO_WHATSAPP_FROM}",
          "TWILIO_SMS_FROM": "${TWILIO_SMS_FROM}",
          "AGENT_API_KEY": "${AGENT_API_KEY}"
        }
      }
    },
    "load": {
      "extraDirs": ["./skills"],
      "watch": true
    }
  },
  "channels": {
    "whatsapp": {
      "enabled": true,
      "dmPolicy": "open",
      "allowFrom": ["*"]
    }
  }
}
